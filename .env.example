PORT=4173
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
MAIL_FROM=your-email@gmail.com
# Optional: preferred on Render because it sends over HTTPS instead of SMTP.
RESEND_API_KEY=
RESEND_FROM=
# Set to 0 only behind a trusted HTTPS inspection proxy.
NAVER_TLS_REJECT_UNAUTHORIZED=1
