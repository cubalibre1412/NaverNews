PORT=4173
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
MAIL_FROM=your-email@gmail.com

# Preferred Gmail option on Render. Sends over HTTPS instead of SMTP.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_USER=your-email@gmail.com

# Set to 0 only behind a trusted HTTPS inspection proxy.
NAVER_TLS_REJECT_UNAUTHORIZED=1
